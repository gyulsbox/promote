{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "packages": {
    ".": {
      "package-name": "promote-cli",
      "release-type": "node",
      "include-component-in-tag": false,
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance" },
        { "type": "tune", "section": "Tuning" },
        { "type": "refactor", "section": "Refactors" },
        { "type": "docs", "section": "Docs" },
        { "type": "test", "section": "Tests" },
        { "type": "revert", "section": "Reverts" },
        { "type": "chore", "section": "Chores", "hidden": true },
        { "type": "ci", "section": "CI", "hidden": true },
        { "type": "build", "section": "Build", "hidden": true }
      ],
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "draft": false,
      "prerelease": false,
      "extra-files": [
        {
          "type": "generic",
          "path": "src/version.ts"
        }
      ]
    }
  },
  "$comment": "release-please reads conventional commit messages since the last tag to decide the next version. Pre-1.0: feat -> minor, fix/perf/tune -> patch. After 1.0 set bump-minor-pre-major to false and breaking changes (BREAKING CHANGE: in footer or ! after type) bump major."
}
